<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.ExhibitionController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search exhibition..." HBox.hgrow="ALWAYS" />
        <ComboBox fx:id="themeFilter" promptText="Filter by theme" />
        <Button text="Search" onAction="#handleSearch" />
        <Button text="Reset" onAction="#handleReset" />
    </HBox>
    <TableView fx:id="exhibitionTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="200" />
            <TableColumn fx:id="galleryColumn" text="Gallery" prefWidth="150" />
            <TableColumn fx:id="startDateColumn" text="Start Date" prefWidth="120" />
            <TableColumn fx:id="endDateColumn" text="End Date" prefWidth="120" />
            <TableColumn fx:id="curatorColumn" text="Instructor" prefWidth="120" />
            <TableColumn fx:id="themeColumn" text="Theme" prefWidth="180" />
            <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="200" />
        </columns>
    </TableView>
    <HBox spacing="10.0" alignment="CENTER_RIGHT">
        <Button text="Add Exhibition" onAction="#handleAdd" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
        <Button text="Delete Exhibition" onAction="#handleDelete" style="-fx-background-color: #f44336; -fx-text-fill: white;" />
    </HBox>
</VBox>
